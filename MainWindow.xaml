<Window x:Class="MarkdownReader.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Markdown Reader"
        Height="800" Width="1000"
        MinHeight="400" MinWidth="500"
        Background="#1e1e1e"
        AllowDrop="True"
        Drop="Window_Drop"
        DragOver="Window_DragOver">

    <Window.Resources>
        <Style x:Key="ToolbarButton" TargetType="Button">
            <Setter Property="Background" Value="#2d2d2d"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3d3d3d"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" Background="#252526" Padding="12,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" Grid.Column="0">
                    <Button x:Name="OpenButton" Content="📂 Open Markdown File" Style="{StaticResource ToolbarButton}" Click="OpenButton_Click"/>
                    <Button x:Name="ReloadButton" Content="↻ Reload" Style="{StaticResource ToolbarButton}" Click="ReloadButton_Click" IsEnabled="False"/>
                </StackPanel>

                <TextBlock x:Name="FileNameText"
                           Grid.Column="1"
                           Text="No file loaded — open a file or drag &amp; drop a .md file here"
                           Foreground="#999999"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"
                           FontSize="13"/>

                <StackPanel Orientation="Horizontal" Grid.Column="2">
                    <TextBlock Text="Font size:" Foreground="#cccccc" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <Button x:Name="FontDownButton" Content="A-" Style="{StaticResource ToolbarButton}" Click="FontDownButton_Click" Padding="10,8"/>
                    <Button x:Name="FontUpButton" Content="A+" Style="{StaticResource ToolbarButton}" Click="FontUpButton_Click" Padding="10,8"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Reading area -->
        <Grid Grid.Row="1">
            <wv2:WebView2 x:Name="MarkdownView" />

            <!-- Placeholder shown before any file is loaded -->
            <Border x:Name="PlaceholderPanel" Background="#1e1e1e">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="📄" FontSize="64" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                    <TextBlock Text="Open a Markdown (.md) file to start reading"
                               Foreground="#888888" FontSize="16" HorizontalAlignment="Center"/>
                    <TextBlock Text="or drag and drop a file anywhere into this window"
                               Foreground="#666666" FontSize="13" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
